# LeadIntel - Example environment variables (NO SECRETS)
# Copy to `.env.local` for local dev.
#
# IMPORTANT:
# - Never commit `.env.local` or any secrets.
# - For production (Vercel), set these in the dashboard Environment Variables UI.
#

# ------------------------------
# App / URLs
# ------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# App environment guard used by runtime safety checks:
# - development | staging | production
NEXT_PUBLIC_APP_ENV=development
# Optional canonical server URL for email links and metadata fallbacks
APP_URL=http://localhost:3000
# Comma-separated allowed origins for POST endpoints (recommended in production)
ALLOWED_ORIGINS=http://localhost:3000

# Production canonical requirement:
# - When running production checks (`npm.cmd run check:production`) or deploying live,
#   set NEXT_PUBLIC_SITE_URL to exactly:
#   https://raelinfo.com

# ------------------------------
# Supabase
# ------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional alias used by some Supabase helpers (if set, preferred over ANON key variable)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=api

# Server-only (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional override (defaults to api fallback)
SUPABASE_DB_SCHEMA=api
SUPABASE_DB_SCHEMA_FALLBACK=api

# ------------------------------
# Stripe
# ------------------------------
# Public (safe in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Server-only (secret)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Pro pricing
# - STRIPE_PRICE_ID_PRO: recurring Pro monthly price
STRIPE_PRICE_ID_PRO=price_pro_recurring_99
# Optional annual Pro price
STRIPE_PRICE_ID_CLOSER_ANNUAL=price_pro_recurring_annual
# Optional Pro+ price (treated as Pro product tier with higher internal limits)
STRIPE_PRICE_ID_CLOSER_PLUS=price_pro_plus_recurring_149
# Optional annual Pro+ price
STRIPE_PRICE_ID_CLOSER_PLUS_ANNUAL=price_pro_plus_recurring_annual
# Agency / team pricing
STRIPE_PRICE_ID_TEAM=price_agency_team_recurring
# Optional annual Agency/team price
STRIPE_PRICE_ID_TEAM_ANNUAL=price_agency_team_recurring_annual
# Optional base+seat split pricing for Agency/team
STRIPE_PRICE_ID_TEAM_BASE=price_agency_base_recurring
STRIPE_PRICE_ID_TEAM_SEAT=price_agency_seat_recurring
STRIPE_PRICE_ID_TEAM_BASE_ANNUAL=price_agency_base_recurring_annual
STRIPE_PRICE_ID_TEAM_SEAT_ANNUAL=price_agency_seat_recurring_annual

# ------------------------------
# Upstash Redis (rate limiting)
# Required in production (do not leave empty in prod)
# ------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ------------------------------
# OpenAI
# ------------------------------
OPENAI_API_KEY=sk-your-openai-key

# ------------------------------
# Resend (optional)
# ------------------------------
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_REPLY_TO_EMAIL=support@yourdomain.com
# Optional brand logo in outbound email templates (HTTPS only). Invalid/non-HTTPS values are ignored safely.
EMAIL_BRAND_IMAGE_URL=https://yourdomain.com/brand/leadintel-logo.png
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# Optional operator notifications for net-new inbound lead captures.
# Notifications are disabled unless both are configured.
LIFECYCLE_ADMIN_NOTIFICATIONS_ENABLED=false
LIFECYCLE_ADMIN_EMAILS=ops@yourdomain.com
# Lifecycle sends are disabled by default.
# If enabling either lifecycle flag in production, RESEND_API_KEY + RESEND_FROM_EMAIL are required.
LIFECYCLE_EMAILS_ENABLED=false

# ------------------------------
# Observability (optional)
# ------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ------------------------------
# Feature flags (optional)
# ------------------------------
# Stripe webhook processing kill-switch (default behavior is enabled unless explicitly false)
FEATURE_STRIPE_WEBHOOK_ENABLED=true
# Enable 3-day app-level trial fields/logic (does not change Stripe billing)
ENABLE_APP_TRIAL=false

# Trial abuse hardening (optional; recommended in production)
ENABLE_TRIAL_FINGERPRINTING=false

# Server-side product analytics (optional; writes to api.product_analytics)
ENABLE_PRODUCT_ANALYTICS=false

# Site reports (optional)
ENABLE_SITE_REPORTS=false
SITE_REPORT_CRON_SECRET=""
ADMIN_USER_ID=""

# Demo: seed synthetic Trigger Events after first pitch generation
ENABLE_DEMO_TRIGGER_EVENTS=true

# Market data provider (optional; when unset, UI uses deterministic mock quotes)
# MARKET_DATA_PROVIDER=none|finnhub|polygon
# MARKET_DATA_API_KEY=your_key_here

# Debug UI (optional; do not set in production)
NEXT_PUBLIC_ENABLE_DEBUG_UI=false

# Autopilot Settings UI (optional; hidden by default)
NEXT_PUBLIC_ENABLE_AUTOPILOT_UI=false

# Client-side product analytics (optional; posts to /api/analytics/track)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Trigger Events ingestion (optional)
# Legacy (single provider):
# TRIGGER_EVENTS_PROVIDER=none|newsapi|custom
#
# Preferred (multi-provider, comma-separated):
TRIGGER_EVENTS_PROVIDERS="newsapi,finnhub,gdelt,rss"
TRIGGER_EVENTS_DEBUG_LOGGING="false"
NEWSAPI_API_KEY="your_newsapi_key_here"
FINNHUB_API_KEY="your_finnhub_key_here"
GDELT_BASE_URL="https://api.gdeltproject.org/api/v2/doc/doc"
CRUNCHBASE_API_KEY=""
TRIGGER_EVENTS_RSS_FEEDS="https://feeds.a.dj.com/rss/RSSMarketsMain.xml,https://www.coindesk.com/arc/outboundfeeds/rss/"
TRIGGER_EVENTS_MAX_PER_PROVIDER="10"
#
# Cron ingestion endpoint protection:
TRIGGER_EVENTS_CRON_SECRET=change-me-long-random-secret


