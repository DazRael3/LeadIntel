{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.ts",
    "scripts/**/*.{ts,js}"
  ],
  "entry": [
    "app/**/page.tsx",
    "app/**/layout.tsx",
    "app/**/route.ts",
    "app/**/error.tsx",
    "scripts/**/*.{ts,js}",
    "tests/e2e/**/*.spec.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.vitest.ts",
    "**/*.vitest.tsx"
  ],
  "ignore": [
    ".next/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**",
    "supabase/.temp/**"
  ],
  "include": ["dependencies", "unlisted", "unresolved", "binaries", "catalog"],
  "ignoreBinaries": ["supabase"]
}

